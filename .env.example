# ═══════════════════════════════════════════════════════════════════
# CodeBox - Environment Configuration
# Copy this file to .env and fill in your values.
# Only uncomment and set the variables you need.
# ═══════════════════════════════════════════════════════════════════

# ─── LLM Providers ───────────────────────────────────────────────
# LLM_API_KEY and LLM_BASE_URL are automatically mapped to ANTHROPIC_API_KEY
# and ANTHROPIC_BASE_URL for Claude Code at startup — no need to
# set the Anthropic-specific vars separately unless you need to override them.
# Note: Claude.ai OAuth login does NOT work in headless Docker; LLM_API_KEY is required.
# LLM_BASE_URL=https://your-llm-provider.example.com
# LLM_API_KEY=your-llm-api-key-here

# OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── Agent Selection ─────────────────────────────────────────────
# opencode    (default) — OpenCode AI agent
# claude-code           — Anthropic Claude Code agent
# CODEBOX_APP=opencode

# ─── OpenCode Settings ───────────────────────────────────────────
# OPENCODE_MODEL=llm/claude-opus-4-6

# Fallback model used at startup if the LLM gateway is unreachable.
# Leave unset to disable automatic fallback.
# OPENCODE_MODEL_FALLBACK=github-copilot/gemini-2.5-pro

# Enable the local prefill-stripping proxy (default: true).
# Set to false to connect directly to LLM_BASE_URL.
# PREFILL_PROXY=true

# Upstream timeout in seconds. If the LLM API doesn't respond within
# this window, the proxy kills the connection and signals an error to
# OpenCode so stuck subagent tasks can recover (default: 120).
# PROXY_TIMEOUT=120

# Log level for the prefill proxy: debug | info | warn | error
# PROXY_LOG_LEVEL=info

# OpenCode TUI color scheme (default: opencode).
# Built-in themes: opencode, catppuccin, dracula, tokyonight, gruvbox, monokai,
#                  flexoki, onedark, tron, nord, everforest, ayu, kanagawa, matrix
# You can also change this at runtime with the /theme command inside OpenCode.
# OPENCODE_TUI_THEME=opencode

# ─── Claude Code Settings ────────────────────────────────────────
# Default model for Claude Code (exported as CLAUDE_MODEL at runtime).
# Common values: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# Leave unset to use Claude Code's built-in default.
# CLAUDE_CODE_MODEL=claude-opus-4-6

# Permission mode for Claude Code (maps to `claude --permission-mode <mode>`).
# Valid: acceptEdits, auto, bypassPermissions, default, dontAsk, plan.
# Use `plan` to start every session in plan mode (read-only until you exit it).
# Leave unset to use Claude Code's default (interactive Shift+Tab toggle still works).
# CLAUDE_CODE_PERMISSION_MODE=plan

# Disable experimental beta features in Claude Code.
# Set to 1 (default) to opt out; set to 0 to re-enable betas.
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# ─── UI & Display ────────────────────────────────────────────────
# web  (default) — browser-based web UI (opencode web, OpenCode only)
# tmux           — terminal UI inside tmux, exposed via ttyd
#                  (persistent session survives browser disconnects,
#                   shell pane toggle with Ctrl-Space m,
#                   `docker exec` attach support)
# "tui" is accepted as an alias for "tmux".
# CODEBOX_MODE=web

# Port for the web UI / TUI (default: 3000).
# ⚠ Changing this requires 'docker compose up' or './codebox.sh rebuild'
#   (stop/start alone cannot change port mappings).
# CODEBOX_PORT=3000

# Browser tab title for tmux mode (default: auto-detected from Docker
# Compose service name, e.g. "OpenCode — my-project" or "Claude Code — my-project").
# Requires Docker socket (/var/run/docker.sock) to be mounted.
# CODEBOX_TITLE=CodeBox

# Initial theme: "dark" (default) or "light".
# Affects tmux status bar, borders, and terminal background.
# Toggle at runtime with Ctrl-Space t.
# CODEBOX_THEME=dark

# ─── tmux ────────────────────────────────────────────────────────
# Timezone for tmux status bar (default: UTC)
# TZ=America/New_York

# Extra arguments passed to ttyd in tmux mode (all agents).
# Clipboard: mouse-select auto-copies, Ctrl+V pastes, Cmd+C/V works on Mac.
# To disable auto-copy: CODEBOX_TUI_ARGS="-t copyOnSelect=false"
# CODEBOX_TUI_ARGS=

# Extra arguments passed directly to the agent binary (all agents).
# CODEBOX_EXTRA_ARGS=

# ─── TLS ─────────────────────────────────────────────────────────
# TLS is enabled by default for tui/tmux modes using mkcert.
# A locally-trusted certificate is auto-generated for localhost + 127.0.0.1.
# The mkcert CA root persists in .docker/mkcert-ca/ (bind mount) and
# survives docker compose down -v — you only import it once.
#
# One-time setup to remove browser warnings:
#   Import .docker/mkcert-ca/rootCA.pem into your OS/browser trust store.
#   (Instructions are printed on first container startup.)
#
# Set to false to disable TLS and serve plain HTTP.
# CODEBOX_TLS=true

# Custom TLS certificate and key paths (optional, skips mkcert).
# CODEBOX_TLS_CERT=/path/to/cert.pem
# CODEBOX_TLS_KEY=/path/to/key.pem

# ─── Workspace ───────────────────────────────────────────────────
# Parent directory containing all your git repos.
# Used in docker-compose.override.yml to mount projects into /workspace.
# For multi-repo workspaces, mount specific repos as subdirectories:
#   - ${REPOS_PATH}/api:/workspace/api
#   - ${REPOS_PATH}/frontend:/workspace/frontend
# See docker-compose.override.yml.example for a full multi-repo example.
# REPOS_PATH=~/repos

# ─── Context Window Optimization ─────────────────────────────────
# Disable features to reduce Claude Code's system prompt size.
# Each MCP server adds 50-150 tool definitions to context; skills/agents add more.

# Disable individual MCP servers (default: true = enabled).
# Set to false to exclude from the generated MCP config.
# CODEBOX_MCP_MEMORY=true
# CODEBOX_MCP_CONTEXT7=true
# CODEBOX_MCP_TIME=true
# CODEBOX_MCP_WEBSEARCH=true
# CODEBOX_MCP_GITHUB_RBI=true
# CODEBOX_MCP_GITHUB_PERSONAL=true
# CODEBOX_MCP_MCP_ATLASSIAN=true
# CODEBOX_MCP_GRAFANA=true
# CODEBOX_MCP_DOCKER=true
# CODEBOX_MCP_SEQUENTIAL_THINKING=true

# Disable BMad skills — removes all bmad-* skill directories (saves ~300K tokens).
# CODEBOX_SKILLS_BMAD=true

# Disable GSD system — removes GSD commands, agents, hooks (saves ~260K tokens).
# CODEBOX_GSD=true

# ══ MCP Integrations ═════════════════════════════════════════════

# ─── GitHub ──────────────────────────────────────────────────────
# GITHUB_ENTERPRISE_URL=https://github.your-company.com
# GITHUB_ENTERPRISE_TOKEN=your-github-enterprise-token-here
# GITHUB_PERSONAL_TOKEN=your-github-personal-token-here

# ─── Atlassian ───────────────────────────────────────────────────
# CONFLUENCE_URL=https://your-confluence.example.com
# CONFLUENCE_USERNAME=your-email@example.com
# CONFLUENCE_TOKEN=your-confluence-token-here

# JIRA_URL=https://your-jira.example.com
# JIRA_USERNAME=your-email@example.com
# JIRA_TOKEN=your-jira-token-here

# Limit which toolsets are exposed to reduce the MCP tools/list
# response size (default: all 72 tools, which can cause timeouts).
# Common values: jira_issues,jira_projects,confluence_pages
# Full list: https://github.com/sooperset/mcp-atlassian#toolsets
# ATLASSIAN_TOOLSETS=jira_issues,jira_projects,confluence_pages,confluence_search

# ─── Grafana ─────────────────────────────────────────────────────
# GRAFANA_URL=https://your-grafana.example.com
# GRAFANA_API_KEY=your-grafana-api-key-here

# ─── Cloudflare ──────────────────────────────────────────────────
# API token for Cloudflare MCP or CLI tools.
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ─── Build / Versions ────────────────────────────────────────────
# Pin to a specific version, or leave as "latest".
# Used at build time: docker compose build --build-arg CODEBOX_VERSION=1.2.15
# Or set here and run: ./codebox.sh update
# CODEBOX_VERSION=latest

# ─── Infrastructure / Advanced ───────────────────────────────────
# Use host networking to eliminate Docker bridge NAT overhead (~70-80ms
# per new TCP connection). Recommended on Linux for lower LLM latency.
# Not supported on Docker Desktop (Mac/Windows) — leave unset there.
# DOCKER_NETWORK_MODE=host

# Path to your corporate CA certificate bundle on the host.
# ~ and absolute paths both work (resolved automatically via Docker).
# Used both at build time (as a Docker build secret for curl/npm) and
# at runtime (volume-mounted to /certs/ca-bundle.pem).
# CA_CERT_PATH=~/certs/ca-bundle.pem

# Path to your host opencode auth.json (for Copilot tokens etc.).
# Merged into the container's auth.json at startup (host entries
# never overwrite container entries like "llm" or "anthropic").
# Defaults to .docker/empty-file (disabled) if not set.
# HOST_AUTH_JSON=~/.local/share/opencode/auth.json

# atl — RBI-internal Atlassian CLI (https://code.rbi.tech/raiffeisen/atl)
# Built into the container image from source (codebox.sh clones it at build time).
# At runtime, provide your config file with Jira/Confluence URLs and PAT tokens:
#
#   # ~/.config/atl/config.yaml
#   jira:
#     url: "https://jira.rbinternational.com/jira"
#     token: "<your-jira-pat>"
#   confluence:
#     url: "https://wiki.rbinternational.com/confluence"
#     token: "<your-confluence-pat>"
#
# See https://code.rbi.tech/raiffeisen/atl for full documentation.
# ATL_CONFIG_FILE=~/.config/atl/config.yaml

# Host bin directories — expose macOS CLI tools (e.g. Homebrew packages)
# inside the container at /host/*-bin (all added to PATH automatically).
# Uncomment the lines matching your machine. Defaults to empty if not set.
# Apple Silicon Mac (Homebrew at /opt/homebrew):
# HOMEBREW_BIN=/opt/homebrew/bin
# HOMEBREW_SBIN=/opt/homebrew/sbin
# Intel Mac / Linux (Homebrew or standard tools at /usr/local):
# USR_LOCAL_BIN=/usr/local/bin
# USR_LOCAL_SBIN=/usr/local/sbin
# User-installed scripts:
# USER_LOCAL_BIN=~/.local/bin

# Path to your .git-credentials file for HTTPS push support.
# Defaults to .docker/empty-file (disabled) if not set.
# GIT_CREDENTIALS_PATH=~/.git-credentials

# Path to a secondary .gitconfig for work identity (e.g. different
# user.name / user.email for corporate repos). Use with a conditional
# include in your main ~/.gitconfig:
#   [includeIf "hasconfig:remote.*.url:https://code.yourcompany.com/**"]
#     path = .gitconfig-work
# Defaults to .docker/empty-file (disabled) if not set.
# GIT_CONFIG_WORK_PATH=~/.gitconfig-work
